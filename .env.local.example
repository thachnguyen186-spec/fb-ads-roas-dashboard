# Supabase — find these in your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Adjust API Revenue Fetch (optional) — enables "Fetch Data from Adjust API" on dashboard
# ADJUST_API_TOKEN: Bearer token from Adjust's Reports API (required if using API fetch)
# ADJUST_ACCOUNT_ID: Adjust account ID (required if using API fetch — needed because Adjust login may have multi-account access)
# ADJUST_APP_TOKEN: Comma-separated list of app tokens to restrict queries. If unset, auto-discovers all apps on the account.
ADJUST_API_TOKEN=
ADJUST_ACCOUNT_ID=
# ADJUST_APP_TOKEN=token1,token2,token3

# Spending Limit Monitor — Vercel Cron + Telegram alerts
# CRON_SECRET: random 32-char string, set in Vercel project env vars (matches vercel.json cron auth)
CRON_SECRET=replace-with-random-32-char-string
# TELEGRAM_BOT_TOKEN: from @BotFather; TELEGRAM_CHAT_ID: group chat ID (negative number for groups)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
